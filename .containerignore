# Build context hygiene for tools/claude/Containerfile (build context = repo root).
# The builder stage COPYs the workspace source to compile debug-mcp; keep the
# context lean so the image build doesn't drag in build outputs, the local
# cargo/registry cache, VCS metadata, editor state, or the compiled C testdata
# fixtures (rebuilt on demand by `make -C testdata`, not a build input).
target/
.cache/
.git/
.idea/
.vscode/
dist/

# Compiled testdata fixtures (the .c sources stay; the build artifacts — bare
# ELF binaries named after each source, plus any .o — don't). Rebuilt in the
# container on demand by `make -C testdata`.
testdata/simple
testdata/loop
testdata/crash
testdata/structs
testdata/multithread
testdata/**/*.o
